FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY pricing_copilot/requirements.txt /app/pricing_copilot/requirements.txt
RUN pip install --no-cache-dir -r /app/pricing_copilot/requirements.txt

COPY pricing_copilot /app/pricing_copilot

EXPOSE 8001
CMD ["uvicorn", "pricing_copilot.main:app", "--host", "0.0.0.0", "--port", "8001"]