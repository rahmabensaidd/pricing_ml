# -----------------------
# DATA
# -----------------------

# 1. IGNORE all cvs
*.csv

# 2. EXCEPT FOR STATIC FOLDERS
!pricing__epac/data/raw/static/
!pricing__epac/data/raw/static/**/*.csv
!pricing__epac/data/raw/static/.gitkeep

# 3. IGNORE CONTENT OF OTHER FOLDERS
pricing__epac/data/consolidated/*
pricing__epac/data/enriched/*
pricing__epac/data/features/*
pricing__epac/data/processed/*
pricing__epac/data/raw/dumps/sql/*

# 4. KEEP STRUCTURE WITH .gitkeep
!pricing__epac/data/consolidated/.gitkeep
!pricing__epac/data/enriched/.gitkeep
!pricing__epac/data/features/.gitkeep
!pricing__epac/data/processed/.gitkeep
!pricing__epac/data/raw/dumps/sql/.gitkeep

