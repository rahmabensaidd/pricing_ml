# -----------------------
# DATA - RÈGLES CLAIRES
# -----------------------

# 1. IGNORER TOUS LES CSV PAR DÉFAUT
*.csv

# 2. EXCEPTIONS POUR LE DOSSIER STATIC
!data/raw/static/
!data/raw/static/**/*.csv
!data/raw/static/.gitkeep

# 3. IGNORER LE CONTENU DES AUTRES DOSSIERS DATA
data/consolidated/*
data/enriched/*
data/features/*
data/processed/*
data/pipeline_results/*
data/raw/dumps/sql/*

# 4. GARDER LA STRUCTURE AVEC .gitkeep
!data/consolidated/.gitkeep
!data/enriched/.gitkeep
!data/features/.gitkeep
!data/processed/.gitkeep
!data/pipeline_results/.gitkeep
!data/raw/dumps/sql/.gitkeep

