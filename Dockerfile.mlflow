ARG MLFLOW_VERSION=3.10.0

FROM python:3.10-slim

ARG MLFLOW_VERSION

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl gcc libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    mlflow==${MLFLOW_VERSION} \
    psycopg2-binary \
    boto3

CMD ["mlflow", "server"]
