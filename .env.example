# MySQL
MYSQL_PASSWORD=root
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_DATABASE=temp_epac
MYSQL_PORT=3307
MYSQL_CHARSET=utf8mb4

# MLflow + MinIO + Postgres
MLFLOW_URI=http://localhost:5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_S3_ACCESS_KEY=minio_admin
MLFLOW_S3_SECRET_KEY=minio_password
MLFLOW_POSTGRES_USER=mlflow_user
MLFLOW_POSTGRES_PASSWORD=mlflow_password
MLFLOW_POSTGRES_DB=mlflow_db
MLFLOW_BUCKET_NAME=mlflow-artifacts
AWS_DEFAULT_REGION=us-east-1

# API
API_HOST=0.0.0.0
API_PORT=8000
PREFECT_API_URL=http://localhost:4200/api
PREFECT_UI_API_URL=http://localhost:4200/api

# Training
TRAIN_TEST_SPLIT=0.25
RANDOM_STATE=42
CV_FOLDS=5
MIN_TARGET_VALUE=0.5
MAX_FEATURES_FOR_IMPORTANCE=50

# Watcher (Docker profile: watcher)
WATCHER_MODE=all
WATCHER_MLFLOW_TRACKING_URI=http://mlflow-server:5000

# Logs
LOG_LEVEL=INFO
